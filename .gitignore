# ── data/ rules ───────────────────────────────────────────────────────────────
# Keep pre-built indexes and catalogue — needed for clone-and-run
# data/index/   ← intentionally NOT ignored (9.7 MB, no git-lfs needed)
# data/          ← intentionally NOT ignored

# Ignore large raw Yelp source dump — too large for git (5+ GB)
data/raw/yelp/
data/yelp_dataset/

# ── local tool / working directories ──────────────────────────────────────────
.claude/
tmp/
.debug/

