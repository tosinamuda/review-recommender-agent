# LLM routing
# LM_MODEL accepts any LiteLLM model string. LiteLLM infers the provider from
# the prefix and reads that provider's standard environment variables.
LM_MODEL=openrouter/openai/gpt-oss-120b

# OpenRouter
OPENROUTER_API_KEY=
OR_APP_NAME=BCT-Hackathon-Review-Simulation
OR_SITE_URL=http://127.0.0.1:8000

# OpenAI / OpenAI-compatible APIs
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1
# LM_MODEL=openai/gpt-4o

# Ollama via OpenAI-compatible local endpoint
# OPENAI_API_KEY=anything
# OPENAI_API_BASE=http://localhost:11434/v1
# LM_MODEL=openai/llama3

# HuggingFace
# After the embedding model (BAAI/bge-small-en-v1.5) has been downloaded once,
# set this to 1 to prevent any further HF Hub network calls (faster startup, no rate-limit warnings).
# HF_HUB_OFFLINE=1
