# Redirect www to non-www
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ www_domain }};

{% if ssl_cert_check.stat.exists %}
    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;
{% else %}
    ssl_certificate /etc/nginx/ssl/{{ app_name }}/placeholder.crt;
    ssl_certificate_key /etc/nginx/ssl/{{ app_name }}/placeholder.key;
{% endif %}

    return 301 https://{{ domain_name }}$request_uri;
}

# Main application server
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ domain_name }};

{% if ssl_cert_check.stat.exists %}
    ssl_certificate /etc/letsencrypt/live/{{ domain_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain_name }}/privkey.pem;
{% else %}
    ssl_certificate /etc/nginx/ssl/{{ app_name }}/placeholder.crt;
    ssl_certificate_key /etc/nginx/ssl/{{ app_name }}/placeholder.key;
{% endif %}

    # SSE streaming endpoints (A2A task streaming — must not be buffered)
    location ~ ^/(a2a|recommendation/a2a) {
        proxy_pass http://127.0.0.1:{{ app_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Disable buffering so SSE events reach the client immediately
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 300s;
        add_header X-Accel-Buffering no;
    }

    # All other traffic — web UI, REST API, health, agent card
    location / {
        proxy_pass http://127.0.0.1:{{ app_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
